{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/source.schema.json",
  "title": "SourceRegistry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": { "const": "apw.source_registry.v0" },
    "sources": { "type": "array", "items": { "$ref": "#/$defs/source_descriptor" } }
  },
  "$defs": {
    "source_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "provider_refs", "source_type", "authority", "url", "allowed_domains", "cadence", "enabled", "parser", "automation_status", "graduation_notes", "graduation_blockers", "snapshot_policy", "license_note", "maintainers"],
      "properties": {
        "key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*[a-z0-9]$|^[a-z0-9]$" },
        "provider_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^provider:[a-z0-9][a-z0-9_-]*$" } },
        "source_type": { "enum": ["pricing_page", "docs_page", "status_page", "rss_feed", "atom_feed", "github_releases", "github_commits", "blog", "social", "third_party_catalog", "manual"] },
        "authority": { "enum": ["official_pricing", "official_docs", "official_status", "official_repo", "official_blog", "official_staff_social", "community_hint", "third_party_catalog", "manual"] },
        "url": { "type": "string", "format": "uri" },
        "allowed_domains": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
        "cadence": { "type": "string", "minLength": 3, "maxLength": 80 },
        "enabled": { "type": "boolean" },
        "parser": { "type": "string", "minLength": 3, "maxLength": 120 },
        "automation_status": { "enum": ["enabled_deterministic", "manual_review_only", "blocked_pending_parser"] },
        "graduation_notes": { "type": "string", "minLength": 3, "maxLength": 240 },
        "graduation_blockers": { "type": "array", "items": { "type": "string", "minLength": 3, "maxLength": 160 } },
        "content_scope": { "$ref": "#/$defs/content_scope" },
        "impact_hints": { "type": "array", "items": { "type": "string", "minLength": 3, "maxLength": 80 } },
        "rate_limit": { "type": ["string", "null"] },
        "robots_policy_note": { "type": ["string", "null"] },
        "snapshot_policy": { "type": "string", "minLength": 3, "maxLength": 160 },
        "license_note": { "type": "string", "minLength": 3, "maxLength": 240 },
        "maintainers": { "type": "array", "items": { "type": "string" } },
        "fixtures": { "type": "array", "items": { "type": "string" } }
      }
    },
    "content_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "start_heading"],
      "properties": {
        "kind": { "const": "html_heading_range" },
        "start_heading": { "type": "string", "minLength": 1, "maxLength": 120 },
        "end_headings": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 120 } }
      }
    }
  }
}
