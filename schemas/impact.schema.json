{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/impact.schema.json",
  "title": "ImpactAssessment",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope_type", "scope_ref", "impact_kind", "direction", "severity", "confidence"],
  "properties": {
    "scope_type": { "enum": ["provider", "provider_surface", "model", "model_alias", "agent_app", "subscription_plan", "api_endpoint", "sdk", "gateway", "cloud_region", "account_type", "unknown"] },
    "scope_ref": { "type": "string", "minLength": 3 },
    "impact_kind": { "enum": ["cost", "quota", "rate_limit", "availability", "migration", "behavior", "quality", "security", "compliance", "unknown"] },
    "direction": { "enum": ["increase", "decrease", "added", "removed", "changed", "unknown"] },
    "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
    "confidence": { "enum": ["low", "medium", "high", "confirmed"] },
    "subscription_impact": { "enum": ["none", "possible", "direct", "unknown"] },
    "api_usage_impact": { "enum": ["none", "possible", "direct", "unknown"] },
    "estimated_cost_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "confidence"],
      "properties": {
        "direction": { "enum": ["increase", "decrease", "neutral", "unknown"] },
        "magnitude": { "type": ["string", "null"] },
        "basis": { "type": ["string", "null"] },
        "confidence": { "enum": ["low", "medium", "high", "confirmed"] }
      }
    },
    "who_should_care": {
      "type": "array",
      "items": { "enum": ["platform_engineers", "finops", "coding_agent_users", "sdk_maintainers", "product_engineers", "reliability_engineers", "security_engineers"] }
    },
    "recommended_action": { "type": "string", "maxLength": 360 }
  }
}
