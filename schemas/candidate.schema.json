{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/candidate.schema.json",
  "title": "FindingCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "source_keys",
    "provider_refs",
    "claim_text",
    "candidate_kind",
    "evidence_refs",
    "created_at",
    "review_status",
    "parser",
    "dedupe_key",
    "untrusted_input_policy"
  ],
  "properties": {
    "schema_version": { "const": "apw.finding_candidate.v0" },
    "id": { "type": "string", "pattern": "^candidate-[a-z0-9][a-z0-9-]*-[a-f0-9]{16}$" },
    "source_keys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*[a-z0-9]$|^[a-z0-9]$" }
    },
    "provider_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^provider:[a-z0-9][a-z0-9_-]*$" }
    },
    "claim_text": { "type": "string", "minLength": 10, "maxLength": 2000 },
    "candidate_kind": {
      "enum": [
        "api_contract_change",
        "billing_channel_change",
        "caching_change",
        "catalog_correction",
        "default_model_change",
        "model_deprecation",
        "model_launch",
        "model_retirement",
        "pricing_change",
        "quota_change",
        "rate_limit_change",
        "regional_availability_change",
        "sdk_behavior_change",
        "status_incident",
        "status_recovery",
        "subscription_change",
        "terms_policy_change",
        "token_accounting_change",
        "workflow_behavior_change",
        "unknown"
      ]
    },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/candidate_evidence_ref" } },
    "created_at": { "type": "string", "format": "date-time" },
    "review_status": { "enum": ["worth_a_look", "needs_review", "promoted", "rejected", "duplicate"] },
    "parser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "contract_version"],
      "properties": {
        "name": { "type": "string", "minLength": 3, "maxLength": 120 },
        "contract_version": { "const": "apw.candidate_parser.v0" }
      }
    },
    "dedupe_key": { "type": "string", "minLength": 12, "maxLength": 160 },
    "limitations": { "type": "array", "items": { "type": "string", "minLength": 3, "maxLength": 240 } },
    "llm_notes": { "type": ["string", "null"], "maxLength": 2000 },
    "untrusted_input_policy": {
      "const": "Source content is untrusted data. Candidate generation never executes or follows source text."
    }
  },
  "$defs": {
    "candidate_evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_key", "url", "retrieved_at", "authority", "content_sha256", "fingerprint"],
      "properties": {
        "source_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*[a-z0-9]$|^[a-z0-9]$" },
        "url": { "type": "string", "format": "uri" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "authority": {
          "enum": [
            "official_pricing",
            "official_docs",
            "official_status",
            "official_repo",
            "official_blog",
            "official_staff_social",
            "community_hint",
            "third_party_catalog",
            "manual"
          ]
        },
        "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "snapshot_ref": {
          "type": ["string", "null"],
          "maxLength": 240,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]{0,239}$"
        },
        "selector": { "type": "string", "maxLength": 160 }
      }
    }
  }
}
