{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/release-verification.schema.json",
  "title": "ReleaseVerificationReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_at",
    "verified",
    "release_id",
    "source_commit",
    "dry_run_report_path",
    "publication_packet_path",
    "artifacts_root",
    "checks",
    "verified_artifacts"
  ],
  "properties": {
    "schema_version": { "const": "apw.release_verification.v0" },
    "created_at": { "type": "string", "format": "date-time" },
    "verified": { "type": "boolean" },
    "release_id": {
      "type": ["string", "null"],
      "pattern": "^data-[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}(\\.[1-9][0-9]*)?$"
    },
    "source_commit": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{40}$"
    },
    "dry_run_report_path": { "type": "string", "minLength": 1 },
    "publication_packet_path": { "type": ["string", "null"], "minLength": 1 },
    "artifacts_root": { "type": ["string", "null"], "minLength": 1 },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "details"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pass", "fail"] },
          "details": { "type": "string" }
        }
      }
    },
    "verified_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
