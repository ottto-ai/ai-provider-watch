{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/release-publication-packet.schema.json",
  "title": "ReleasePublicationPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "release_date",
    "source_commit",
    "created_at",
    "publication_decision",
    "dry_run",
    "reviewed_inputs",
    "required_external_evidence",
    "signing",
    "token_boundary",
    "rollback"
  ],
  "properties": {
    "schema_version": { "const": "apw.release_publication_packet.v0" },
    "release_id": { "type": "string", "pattern": "^data-[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}$" },
    "release_date": { "type": "string", "format": "date" },
    "source_commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "publication_decision": { "enum": ["publish", "skip"] },
    "dry_run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_path", "report_sha256", "check_count", "artifact_count"],
      "properties": {
        "report_path": { "type": "string", "minLength": 1 },
        "report_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "check_count": { "type": "integer", "minimum": 1 },
        "artifact_count": { "type": "integer", "minimum": 1 }
      }
    },
    "reviewed_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewed_event_ids",
        "source_owner",
        "source_owner_approval_ref",
        "no_reviewed_events_reason"
      ],
      "properties": {
        "reviewed_event_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "source_owner": { "type": "string", "minLength": 1 },
        "source_owner_approval_ref": { "type": "string", "minLength": 1 },
        "no_reviewed_events_reason": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "required_external_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_protection_ref",
        "ci_ref",
        "codeql_workflow_ref",
        "code_scanning_ref",
        "dependency_review_ref",
        "attestation_ref",
        "checksum_review_ref",
        "release_manager_approval_ref"
      ],
      "properties": {
        "branch_protection_ref": { "type": "string", "minLength": 1 },
        "ci_ref": { "type": "string", "minLength": 1 },
        "codeql_workflow_ref": { "type": "string", "minLength": 1 },
        "code_scanning_ref": { "type": "string", "minLength": 1 },
        "dependency_review_ref": { "type": "string", "minLength": 1 },
        "attestation_ref": { "type": "string", "minLength": 1 },
        "checksum_review_ref": { "type": "string", "minLength": 1 },
        "release_manager_approval_ref": { "type": "string", "minLength": 1 }
      }
    },
    "signing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanism", "tag_name", "required_commands", "key_boundary"],
      "properties": {
        "mechanism": { "const": "manual_release_manager_signed_git_tag" },
        "tag_name": { "type": "string", "pattern": "^data-[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}$" },
        "required_commands": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "key_boundary": { "type": "string", "minLength": 1 }
      }
    },
    "token_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publisher_workflow_mode",
        "no_release_tokens_in_untrusted_lanes",
        "forbidden_untrusted_lanes"
      ],
      "properties": {
        "publisher_workflow_mode": { "const": "protected_main_noop_or_packet_only" },
        "no_release_tokens_in_untrusted_lanes": { "const": true },
        "forbidden_untrusted_lanes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "forbidden_actions"],
      "properties": {
        "policy": { "type": "string", "minLength": 1 },
        "forbidden_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
