{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/release-automation-readiness.schema.json",
  "title": "ReleaseAutomationReadiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "generated_by",
    "status",
    "summary",
    "checks",
    "decision_blockers",
    "token_boundary",
    "policy",
    "references"
  ],
  "properties": {
    "schema_version": { "const": "apw.release_automation_readiness.v0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by": { "type": "string", "minLength": 1 },
    "status": { "enum": ["blocked", "fail", "ready_for_publish_pr"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_mode",
        "publisher_mode",
        "target_mode",
        "blocking_decision",
        "check_count",
        "pass_count",
        "fail_count",
        "warn_count",
        "decision_blocker_count"
      ],
      "properties": {
        "current_mode": { "type": "string", "minLength": 1 },
        "publisher_mode": { "type": "string", "minLength": 1 },
        "target_mode": { "type": "string", "minLength": 1 },
        "blocking_decision": { "type": ["string", "null"], "minLength": 1 },
        "check_count": { "type": "integer", "minimum": 0 },
        "pass_count": { "type": "integer", "minimum": 0 },
        "fail_count": { "type": "integer", "minimum": 0 },
        "warn_count": { "type": "integer", "minimum": 0 },
        "decision_blocker_count": { "type": "integer", "minimum": 0 }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    },
    "decision_blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision_blocker" }
    },
    "token_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publisher_workflow",
        "dry_run_workflow",
        "protected_environment",
        "untrusted_lanes",
        "no_release_tokens_in_untrusted_lanes",
        "publisher_has_release_authority"
      ],
      "properties": {
        "publisher_workflow": { "type": "string", "minLength": 1 },
        "dry_run_workflow": { "type": "string", "minLength": 1 },
        "protected_environment": { "type": "string", "minLength": 1 },
        "untrusted_lanes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "no_release_tokens_in_untrusted_lanes": { "type": "boolean" },
        "publisher_has_release_authority": { "type": "boolean" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manual_signed_tag_baseline",
        "artifact_attestations",
        "secrets",
        "publication"
      ],
      "properties": {
        "manual_signed_tag_baseline": { "type": "string", "minLength": 1 },
        "artifact_attestations": { "type": "string", "minLength": 1 },
        "secrets": { "type": "string", "minLength": 1 },
        "publication": { "type": "string", "minLength": 1 }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        }
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "details", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "warn", "fail"] },
        "details": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decision_blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "recommendation",
        "tradeoffs",
        "evidence"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["required", "approved", "deferred"] },
        "recommendation": { "type": "string", "minLength": 1 },
        "tradeoffs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
