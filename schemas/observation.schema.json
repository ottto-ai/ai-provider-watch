{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/observation.schema.json",
  "title": "Observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_key", "retrieved_at", "final_url", "http_status", "content_type", "content_sha256", "fingerprint", "changed"],
  "properties": {
    "schema_version": { "const": "apw.observation.v0" },
    "source_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*[a-z0-9]$|^[a-z0-9]$" },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "final_url": { "type": "string", "format": "uri" },
    "http_status": { "type": "integer", "minimum": 100, "maximum": 599 },
    "content_type": { "type": ["string", "null"] },
    "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "changed": { "type": "boolean" },
    "items": { "type": "array", "items": { "type": "object" } },
    "raw_excerpt_hashes": { "type": "array", "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
    "candidate_claims": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 10, "maxLength": 2000 },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["claim_text"],
            "properties": {
              "claim_text": { "type": "string", "minLength": 10, "maxLength": 2000 },
              "evidence_url": { "type": "string", "format": "uri", "maxLength": 500 },
              "snapshot_ref": {
                "type": "string",
                "maxLength": 240,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]{0,239}$"
              },
              "selector": {
                "type": "string",
                "maxLength": 160,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]{0,159}$"
              },
              "candidate_kind": {
                "enum": [
                  "api_contract_change",
                  "billing_channel_change",
                  "caching_change",
                  "catalog_correction",
                  "default_model_change",
                  "model_deprecation",
                  "model_launch",
                  "model_retirement",
                  "pricing_change",
                  "quota_change",
                  "rate_limit_change",
                  "regional_availability_change",
                  "sdk_behavior_change",
                  "status_incident",
                  "status_recovery",
                  "subscription_change",
                  "terms_policy_change",
                  "token_accounting_change",
                  "workflow_behavior_change",
                  "unknown"
                ]
              }
            }
          }
        ]
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } },
    "snapshot_ref": {
      "type": ["string", "null"],
      "maxLength": 240,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]{0,239}$"
    }
  }
}
