{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/promotion-readiness.schema.json",
  "title": "PromotionReadinessReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "created_at", "candidate_count", "policy", "summary", "candidates"],
  "properties": {
    "schema_version": { "const": "apw.promotion_readiness_report.v0" },
    "created_at": { "type": "string", "format": "date-time" },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "provider_controlled_authorities",
        "high_signal_kinds",
        "dated_source_types",
        "dated_parser_names",
        "forbidden_authority"
      ],
      "properties": {
        "authority": { "const": "advisory_only" },
        "provider_controlled_authorities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3, "maxLength": 80 }
        },
        "high_signal_kinds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3, "maxLength": 80 }
        },
        "dated_source_types": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3, "maxLength": 80 }
        },
        "dated_parser_names": {
          "type": "array",
          "items": { "type": "string", "minLength": 3, "maxLength": 120 }
        },
        "forbidden_authority": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3, "maxLength": 80 }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readiness_counts", "recommendation_counts", "promotion_ready_candidate_ids"],
      "properties": {
        "readiness_counts": { "$ref": "#/$defs/counts" },
        "recommendation_counts": { "$ref": "#/$defs/counts" },
        "promotion_ready_candidate_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/candidate_id" }
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate_report" }
    }
  },
  "$defs": {
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate-[a-z0-9][a-z0-9-]*-[a-f0-9]{16}$|^<invalid-id>$"
    },
    "counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "candidate_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "path",
        "candidate_kind",
        "source_keys",
        "provider_refs",
        "dedupe_key",
        "readiness",
        "recommendation",
        "score",
        "flags",
        "reasons",
        "promotion_blockers",
        "canonical_event_hints",
        "evidence_refs",
        "claim_text"
      ],
      "properties": {
        "candidate_id": { "$ref": "#/$defs/candidate_id" },
        "path": { "type": "string", "minLength": 1, "maxLength": 300 },
        "candidate_kind": { "type": "string", "minLength": 3, "maxLength": 80 },
        "source_keys": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*[a-z0-9]$|^[a-z0-9]$" }
        },
        "provider_refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^provider:[a-z0-9][a-z0-9_-]*$" }
        },
        "dedupe_key": { "type": "string", "minLength": 3, "maxLength": 220 },
        "readiness": {
          "enum": [
            "not_ready",
            "needs_source_owner_review",
            "auto_promotion_eligible",
            "duplicate_or_superseded"
          ]
        },
        "recommendation": { "enum": ["promote", "reject", "duplicate", "needs_human_review"] },
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "flags": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "official_provider_controlled",
            "enabled_deterministic",
            "allowed_evidence",
            "high_signal_kind",
            "dated_source_signal",
            "concrete_date_signal",
            "specific_subject_signal",
            "specific_fact_signal",
            "schema_safe",
            "prompt_safe",
            "no_duplicate_in_window"
          ],
          "properties": {
            "official_provider_controlled": { "type": "boolean" },
            "enabled_deterministic": { "type": "boolean" },
            "allowed_evidence": { "type": "boolean" },
            "high_signal_kind": { "type": "boolean" },
            "dated_source_signal": { "type": "boolean" },
            "concrete_date_signal": { "type": "boolean" },
            "specific_subject_signal": { "type": "boolean" },
            "specific_fact_signal": { "type": "boolean" },
            "schema_safe": { "type": "boolean" },
            "prompt_safe": { "type": "boolean" },
            "no_duplicate_in_window": { "type": "boolean" }
          }
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 3, "maxLength": 240 }
        },
        "promotion_blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 3, "maxLength": 300 }
        },
        "canonical_event_hints": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["event_kind", "provider_refs", "source_authorities", "source_types", "impact_kinds", "evidence_refs"],
          "properties": {
            "event_kind": { "type": "string", "minLength": 3, "maxLength": 80 },
            "provider_refs": {
              "type": "array",
              "items": { "type": "string", "pattern": "^provider:[a-z0-9][a-z0-9_-]*$" }
            },
            "source_authorities": {
              "type": "array",
              "items": { "type": "string", "minLength": 3, "maxLength": 80 }
            },
            "source_types": {
              "type": "array",
              "items": { "type": "string", "minLength": 3, "maxLength": 80 }
            },
            "impact_kinds": {
              "type": "array",
              "items": {
                "enum": [
                  "cost",
                  "quota",
                  "rate_limit",
                  "availability",
                  "migration",
                  "behavior",
                  "quality",
                  "security",
                  "compliance",
                  "unknown"
                ]
              }
            },
            "evidence_refs": {
              "type": "array",
              "items": { "$ref": "#/$defs/evidence_ref" }
            }
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_ref" }
        },
        "claim_text": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "policy", "sha256", "char_count", "prompt_like"],
          "properties": {
            "included": { "const": false },
            "policy": { "type": "string", "minLength": 20, "maxLength": 200 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$|^<invalid-sha256>$" },
            "char_count": { "type": "integer", "minimum": 0 },
            "prompt_like": { "type": "boolean" }
          }
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_key", "url", "authority", "retrieved_at"],
      "properties": {
        "source_key": { "type": "string", "minLength": 1, "maxLength": 120 },
        "url": { "type": "string", "minLength": 1, "maxLength": 500 },
        "authority": { "type": "string", "minLength": 3, "maxLength": 80 },
        "retrieved_at": { "type": "string", "minLength": 3, "maxLength": 80 }
      }
    }
  }
}
