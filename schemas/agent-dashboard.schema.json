{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/agent-dashboard.schema.json",
  "title": "AgentDashboard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "filters",
    "event_count",
    "cards",
    "untrusted_input_policy",
    "delivery_boundary"
  ],
  "properties": {
    "schema_version": { "const": "apw.agent_dashboard.v0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source": { "$ref": "#/$defs/source" },
    "filters": { "$ref": "#/$defs/filters" },
    "event_count": { "type": "integer", "minimum": 0 },
    "cards": {
      "type": "array",
      "items": { "$ref": "#/$defs/card" }
    },
    "untrusted_input_policy": { "type": "string", "minLength": 40, "maxLength": 400 },
    "delivery_boundary": { "const": "local_dashboard_json_no_third_party_api_calls" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "license"],
      "properties": {
        "name": { "const": "AI Provider Watch" },
        "url": { "type": "string", "format": "uri" },
        "license": { "const": "CC0-1.0" }
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["since", "risk", "provider", "kind", "event_id", "agent_app", "limit"],
      "properties": {
        "since": { "type": "string", "minLength": 2, "maxLength": 20 },
        "risk": {
          "type": ["string", "null"],
          "enum": ["info", "low", "medium", "high", "critical", null]
        },
        "provider": { "type": ["string", "null"], "maxLength": 120 },
        "kind": { "type": ["string", "null"], "maxLength": 80 },
        "event_id": { "type": ["string", "null"], "maxLength": 160 },
        "agent_app": { "type": ["string", "null"], "pattern": "^app:[a-z0-9][a-z0-9-]*$" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 50 }
      }
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "title",
        "event_kind",
        "lifecycle_status",
        "event_date",
        "observed_at",
        "effective_at",
        "severity",
        "priority",
        "confidence",
        "source_authority",
        "provider_refs",
        "agent_app_refs",
        "summary",
        "impact_rows",
        "recommended_next_steps",
        "evidence_urls"
      ],
      "properties": {
        "event_id": { "type": "string", "minLength": 3, "maxLength": 160 },
        "title": { "type": "string", "minLength": 8, "maxLength": 140 },
        "event_kind": { "type": "string", "minLength": 3, "maxLength": 80 },
        "lifecycle_status": { "type": "string", "minLength": 3, "maxLength": 40 },
        "event_date": { "type": "string", "format": "date" },
        "observed_at": { "type": "string", "format": "date-time" },
        "effective_at": { "type": ["string", "null"], "format": "date-time" },
        "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
        "priority": { "enum": ["info", "watch", "high", "urgent"] },
        "confidence": { "enum": ["low", "medium", "high", "confirmed"] },
        "source_authority": { "type": "string", "minLength": 3, "maxLength": 80 },
        "provider_refs": { "type": "array", "items": { "type": "string", "minLength": 3 } },
        "agent_app_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^app:[a-z0-9][a-z0-9-]*$" }
        },
        "summary": { "type": "string", "minLength": 20, "maxLength": 420 },
        "impact_rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/impact_row" }
        },
        "recommended_next_steps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 20, "maxLength": 420 }
        },
        "evidence_urls": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        }
      }
    },
    "impact_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_ref",
        "impact_kind",
        "direction",
        "severity",
        "confidence",
        "recommended_action"
      ],
      "properties": {
        "scope_ref": { "type": "string", "pattern": "^app:[a-z0-9][a-z0-9-]*$" },
        "impact_kind": { "type": "string", "minLength": 3, "maxLength": 80 },
        "direction": { "type": "string", "minLength": 3, "maxLength": 80 },
        "severity": { "type": "string", "minLength": 3, "maxLength": 80 },
        "confidence": { "type": "string", "minLength": 3, "maxLength": 80 },
        "subscription_impact": { "type": "string", "minLength": 3, "maxLength": 80 },
        "api_usage_impact": { "type": "string", "minLength": 3, "maxLength": 80 },
        "recommended_action": { "type": "string", "minLength": 20, "maxLength": 420 },
        "estimated_cost_effect": {
          "type": "object",
          "additionalProperties": false,
          "required": ["direction", "magnitude", "confidence"],
          "properties": {
            "direction": { "type": "string", "minLength": 3, "maxLength": 80 },
            "magnitude": { "type": "string", "minLength": 3, "maxLength": 240 },
            "confidence": { "type": "string", "minLength": 3, "maxLength": 80 }
          }
        }
      }
    }
  }
}
