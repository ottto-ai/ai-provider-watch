{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/release-evidence-index.schema.json",
  "title": "ReleaseEvidenceIndex",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "created_at",
    "source_commit",
    "generated_by",
    "repository",
    "package",
    "release_artifacts",
    "local_verification",
    "external_evidence",
    "github_workflows",
    "token_boundary",
    "policies"
  ],
  "properties": {
    "schema_version": { "const": "apw.release_evidence_index.v0" },
    "release_id": { "type": "string", "pattern": "^(dev|data-[0-9]{4}\\.[0-9]{2}\\.[0-9]{2})$" },
    "created_at": { "type": "string", "format": "date-time" },
    "source_commit": { "type": ["string", "null"], "pattern": "^[a-f0-9]{40}$" },
    "generated_by": { "type": "string", "minLength": 1 },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "name", "url", "default_branch"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "default_branch": { "type": "string", "minLength": 1 }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "cli", "pypi_url", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "cli": { "type": "string", "minLength": 1 },
        "pypi_url": { "type": "string", "format": "uri" },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "release_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "purpose", "required_for_release"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "required_for_release": { "type": "boolean" }
        }
      }
    },
    "local_verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "command", "required"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        }
      }
    },
    "external_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "command", "reference_url", "blocked_if_missing"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["required", "optional"] },
          "command": { "type": "string", "minLength": 1 },
          "reference_url": { "type": "string", "minLength": 1 },
          "blocked_if_missing": { "type": "boolean" }
        }
      }
    },
    "github_workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "authority", "required_permissions", "forbidden_capabilities"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "authority": { "type": "string", "minLength": 1 },
          "required_permissions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "forbidden_capabilities": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "token_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_release_tokens_in_untrusted_lanes", "untrusted_lanes", "release_authority_lanes"],
      "properties": {
        "no_release_tokens_in_untrusted_lanes": { "type": "boolean" },
        "untrusted_lanes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "release_authority_lanes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  }
}
