{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/llm-review-result.schema.json",
  "title": "LLMReviewResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_schema_version",
    "reviewer",
    "verdict",
    "findings",
    "review_decisions",
    "residual_risks",
    "forbidden_actions_confirmed_absent"
  ],
  "properties": {
    "schema_version": { "const": "apw.llm_review_result.v0" },
    "request_schema_version": { "const": "apw.llm_review_request.v0" },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "model"],
      "properties": {
        "backend": { "enum": ["codex", "vertex-gemini-flash"] },
        "model": { "type": "string", "minLength": 3, "maxLength": 120 }
      }
    },
    "verdict": { "enum": ["no_blockers_found", "changes_requested", "needs_human_review"] },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "review_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/review_decision" }
    },
    "residual_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 3, "maxLength": 360 }
    },
    "forbidden_actions_confirmed_absent": { "const": true }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "category", "candidate_id", "summary", "evidence_refs", "suggested_fix", "confidence"],
      "properties": {
        "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
        "category": {
          "enum": [
            "schema",
            "evidence",
            "impact",
            "prompt_injection",
            "security",
            "duplicate",
            "other"
          ]
        },
        "candidate_id": {
          "type": ["string", "null"],
          "pattern": "^candidate-[a-z0-9][a-z0-9-]*-[a-f0-9]{16}$"
        },
        "summary": { "type": "string", "minLength": 10, "maxLength": 500 },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_key", "url"],
            "properties": {
              "source_key": { "type": "string", "minLength": 1, "maxLength": 120 },
              "url": { "type": "string", "minLength": 3, "maxLength": 500 }
            }
          }
        },
        "suggested_fix": { "type": ["string", "null"], "maxLength": 1000 },
        "confidence": { "enum": ["low", "medium", "high"] }
      }
    },
    "review_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "decision",
        "rationale",
        "evidence_refs",
        "promotion_readiness",
        "promotion_blockers",
        "confidence"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "pattern": "^candidate-[a-z0-9][a-z0-9-]*-[a-f0-9]{16}$"
        },
        "decision": {
          "enum": ["promote", "reject", "duplicate", "split", "needs_human_review"]
        },
        "rationale": { "type": "string", "minLength": 10, "maxLength": 500 },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_key", "url"],
            "properties": {
              "source_key": { "type": "string", "minLength": 1, "maxLength": 120 },
              "url": { "type": "string", "minLength": 3, "maxLength": 500 }
            }
          }
        },
        "duplicate_of": {
          "type": ["string", "null"],
          "pattern": "^candidate-[a-z0-9][a-z0-9-]*-[a-f0-9]{16}$"
        },
        "duplicate_of_event_id": {
          "type": ["string", "null"],
          "minLength": 3,
          "maxLength": 160
        },
        "split_notes": { "type": ["string", "null"], "maxLength": 500 },
        "promotion_readiness": {
          "enum": [
            "not_ready",
            "needs_source_owner_review",
            "auto_promotion_eligible",
            "duplicate_or_superseded"
          ]
        },
        "promotion_blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 3, "maxLength": 240 }
        },
        "canonical_event_hints": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["event_kind", "provider_refs", "source_authorities", "source_types", "impact_kinds", "evidence_refs"],
          "properties": {
            "event_kind": {
              "enum": [
                "pricing_change",
                "quota_change",
                "rate_limit_change",
                "model_launch",
                "model_deprecation",
                "model_retirement",
                "default_model_change",
                "token_accounting_change",
                "caching_change",
                "billing_channel_change",
                "api_contract_change",
                "sdk_behavior_change",
                "status_incident",
                "status_recovery",
                "subscription_change",
                "terms_policy_change",
                "regional_availability_change",
                "workflow_behavior_change",
                "catalog_correction"
              ]
            },
            "provider_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^provider:[a-z0-9][a-z0-9_-]*$"
              }
            },
            "source_authorities": {
              "type": "array",
              "minItems": 1,
              "items": {
                "enum": [
                  "official_pricing",
                  "official_docs",
                  "official_status",
                  "official_repo",
                  "official_blog",
                  "official_staff_social",
                  "community_hint",
                  "third_party_catalog",
                  "manual"
                ]
              }
            },
            "source_types": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 3, "maxLength": 80 }
            },
            "impact_kinds": {
              "type": "array",
              "minItems": 1,
              "items": {
                "enum": [
                  "cost",
                  "quota",
                  "rate_limit",
                  "availability",
                  "migration",
                  "behavior",
                  "quality",
                  "security",
                  "compliance",
                  "unknown"
                ]
              }
            },
            "evidence_refs": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source_key", "url", "authority", "retrieved_at"],
                "properties": {
                  "source_key": { "type": "string", "minLength": 1, "maxLength": 120 },
                  "url": { "type": "string", "minLength": 3, "maxLength": 500 },
                  "authority": { "type": "string", "minLength": 3, "maxLength": 80 },
                  "retrieved_at": { "type": "string", "minLength": 3, "maxLength": 80 }
                }
              }
            }
          }
        },
        "confidence": { "enum": ["low", "medium", "high"] }
      }
    }
  }
}
