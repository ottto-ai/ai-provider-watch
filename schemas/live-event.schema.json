{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/live-event.schema.json",
  "title": "APW Live Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "state",
    "publication_lane",
    "source_authority",
    "parser_confidence",
    "reason_codes",
    "title",
    "summary",
    "event_kind",
    "provider_refs",
    "event_date",
    "observed_at",
    "published_at",
    "severity",
    "confidence",
    "evidence_refs",
    "derived_from",
    "policy"
  ],
  "properties": {
    "schema_version": { "const": "apw.live_event.v0" },
    "id": { "type": "string", "pattern": "^live-[a-z0-9][a-z0-9-]*-[a-f0-9]{12}$" },
    "state": {
      "enum": ["automated", "agent_reviewed", "needs_followup", "superseded", "promoted", "retracted"]
    },
    "publication_lane": {
      "enum": ["auto", "agent_review", "needs_followup", "candidate_only", "promoted"]
    },
    "source_authority": { "$ref": "#/$defs/source_authority" },
    "parser_confidence": { "enum": ["high", "medium", "low"] },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,80}$" }
    },
    "title": { "type": "string", "minLength": 8, "maxLength": 140 },
    "summary": { "type": "string", "minLength": 20, "maxLength": 420 },
    "event_kind": { "$ref": "#/$defs/event_kind" },
    "provider_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^provider:[a-z0-9][a-z0-9_-]*$" }
    },
    "event_date": { "type": "string", "format": "date" },
    "observed_at": { "type": "string", "format": "date-time" },
    "published_at": { "type": "string", "format": "date-time" },
    "severity": { "$ref": "#/$defs/severity" },
    "confidence": { "$ref": "#/$defs/confidence" },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "impacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/impact" }
    },
    "derived_from": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["provider_event", "finding_candidate"] },
        "id": { "type": "string", "minLength": 8, "maxLength": 240 }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provisional", "untrusted_input_policy", "correction_policy"],
      "properties": {
        "provisional": { "type": "boolean" },
        "untrusted_input_policy": {
          "type": "string",
          "pattern": "untrusted data"
        },
        "correction_policy": {
          "type": "string",
          "pattern": "superseded|retracted|promoted"
        }
      }
    }
  },
  "$defs": {
    "event_kind": {
      "enum": [
        "pricing_change",
        "quota_change",
        "rate_limit_change",
        "model_launch",
        "model_deprecation",
        "model_retirement",
        "default_model_change",
        "token_accounting_change",
        "caching_change",
        "billing_channel_change",
        "api_contract_change",
        "sdk_behavior_change",
        "status_incident",
        "status_recovery",
        "subscription_change",
        "terms_policy_change",
        "regional_availability_change",
        "workflow_behavior_change",
        "catalog_correction",
        "unknown"
      ]
    },
    "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
    "confidence": { "enum": ["low", "medium", "high", "confirmed"] },
    "source_authority": {
      "enum": [
        "official_pricing",
        "official_docs",
        "official_status",
        "official_repo",
        "official_blog",
        "official_staff_social",
        "community_hint",
        "third_party_catalog",
        "manual"
      ]
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_key", "url", "retrieved_at", "authority", "content_sha256"],
      "properties": {
        "source_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*[a-z0-9]$|^[a-z0-9]$" },
        "url": { "type": "string", "format": "uri" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "authority": { "$ref": "#/$defs/source_authority" },
        "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "snapshot_ref": { "type": ["string", "null"], "maxLength": 240 },
        "selector": { "type": ["string", "null"], "maxLength": 160 }
      }
    },
    "impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_type", "scope_ref", "impact_kind", "direction", "severity", "confidence"],
      "properties": {
        "scope_type": { "type": "string", "minLength": 1 },
        "scope_ref": { "type": "string", "minLength": 1 },
        "impact_kind": { "type": "string", "minLength": 1 },
        "direction": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    }
  }
}
