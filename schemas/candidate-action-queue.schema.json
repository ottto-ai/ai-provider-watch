{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/candidate-action-queue.schema.json",
  "title": "CandidateActionQueue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_at",
    "candidate_count",
    "policy",
    "summary",
    "commands",
    "groups"
  ],
  "properties": {
    "schema_version": { "const": "apw.candidate_action_queue.v0" },
    "created_at": { "type": "string", "format": "date-time" },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "purpose", "untrusted_text_policy", "forbidden_authority"],
      "properties": {
        "authority": { "const": "advisory_review_queue_only" },
        "purpose": { "type": "string", "minLength": 20 },
        "untrusted_text_policy": { "type": "string", "minLength": 20 },
        "forbidden_authority": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommended_action_counts",
        "quality_tier_counts",
        "promotion_ready_count",
        "fast_promote_candidate_ids",
        "duplicate_candidate_ids",
        "reject_candidate_ids",
        "needs_human_review_candidate_ids"
      ],
      "properties": {
        "recommended_action_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "quality_tier_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "promotion_ready_count": { "type": "integer", "minimum": 0 },
        "fast_promote_candidate_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "duplicate_candidate_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "reject_candidate_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "needs_human_review_candidate_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_scaffold_event", "source_owner_packet", "candidate_event_packet", "validate_after_promotion"],
      "properties": {
        "candidate_scaffold_event": { "type": "string", "minLength": 10 },
        "source_owner_packet": { "type": "string", "minLength": 10 },
        "candidate_event_packet": { "type": "string", "minLength": 10 },
        "validate_after_promotion": { "type": "array", "items": { "type": "string" } }
      }
    },
    "groups": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promote", "needs_human_review", "duplicate", "reject"],
      "properties": {
        "promote": { "$ref": "#/$defs/queue_rows" },
        "needs_human_review": { "$ref": "#/$defs/queue_rows" },
        "duplicate": { "$ref": "#/$defs/queue_rows" },
        "reject": { "$ref": "#/$defs/queue_rows" }
      }
    }
  },
  "$defs": {
    "queue_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/queue_row" }
    },
    "queue_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "path",
        "candidate_kind",
        "provider_refs",
        "source_keys",
        "quality_tier",
        "recommended_action",
        "score",
        "promotion_readiness",
        "duplicate_event_ids",
        "evidence_refs",
        "next_step"
      ],
      "properties": {
        "candidate_id": { "type": "string" },
        "path": { "type": "string" },
        "candidate_kind": { "type": "string" },
        "provider_refs": { "type": "array", "items": { "type": "string" } },
        "source_keys": { "type": "array", "items": { "type": "string" } },
        "quality_tier": { "type": "string" },
        "recommended_action": {
          "enum": ["promote", "needs_human_review", "duplicate", "reject"]
        },
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "promotion_readiness": { "type": "string" },
        "duplicate_event_ids": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_key", "url", "authority"],
            "properties": {
              "source_key": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "authority": { "type": "string" },
              "selector": { "type": ["string", "null"] },
              "snapshot_ref": { "type": ["string", "null"] }
            }
          }
        },
        "next_step": { "type": "string", "minLength": 10 }
      }
    }
  }
}
