{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/v1-launch-gate.schema.json",
  "title": "V1LaunchGate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "generated_by",
    "status",
    "summary",
    "repository",
    "package",
    "required_feed_artifacts",
    "local_checks",
    "external_smoke_steps",
    "policy"
  ],
  "properties": {
    "schema_version": { "const": "apw.v1_launch_gate.v0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by": { "type": "string", "minLength": 1 },
    "status": { "enum": ["manual_required", "fail"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_check_count",
        "local_pass_count",
        "local_fail_count",
        "external_smoke_step_count",
        "required_feed_artifact_count"
      ],
      "properties": {
        "local_check_count": { "type": "integer", "minimum": 0 },
        "local_pass_count": { "type": "integer", "minimum": 0 },
        "local_fail_count": { "type": "integer", "minimum": 0 },
        "external_smoke_step_count": { "type": "integer", "minimum": 0 },
        "required_feed_artifact_count": { "type": "integer", "minimum": 0 }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "name", "url", "default_branch"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "default_branch": { "type": "string", "minLength": 1 }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "cli", "version", "pypi_url"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "cli": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "pypi_url": { "type": "string", "format": "uri" }
      }
    },
    "required_feed_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "local_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/local_check" }
    },
    "external_smoke_steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/external_smoke_step" }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_private_ottto_dependency",
        "untrusted_input",
        "publication",
        "credentials"
      ],
      "properties": {
        "no_private_ottto_dependency": { "type": "string", "minLength": 1 },
        "untrusted_input": { "type": "string", "minLength": 1 },
        "publication": { "type": "string", "minLength": 1 },
        "credentials": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "local_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "details", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "fail"] },
        "details": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "external_smoke_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "command",
        "expected",
        "required",
        "network_required",
        "trust_boundary"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "expected": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "network_required": { "type": "boolean" },
        "trust_boundary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
