{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-provider-watch.org/schemas/feed-freshness.schema.json",
  "title": "FeedFreshness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "generated_by",
    "package_version",
    "release_id",
    "data_tag",
    "event_count",
    "latest_event_date",
    "latest_observed_at",
    "source_state",
    "release_artifacts",
    "feed_artifacts",
    "freshness_policy"
  ],
  "properties": {
    "schema_version": { "const": "apw.feed_freshness.v0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by": { "type": "string", "minLength": 1 },
    "package_version": { "type": "string", "minLength": 1 },
    "release_id": {
      "type": "string",
      "pattern": "^(dev|data-[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}(\\.[1-9][0-9]*)?)$"
    },
    "data_tag": {
      "type": ["string", "null"],
      "pattern": "^data-[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}(\\.[1-9][0-9]*)?$"
    },
    "event_count": { "type": "integer", "minimum": 0 },
    "latest_event_date": { "type": ["string", "null"], "format": "date" },
    "latest_observed_at": { "type": "string", "format": "date-time" },
    "source_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "present",
        "sha256",
        "bytes",
        "source_count",
        "latest_retrieved_at"
      ],
      "properties": {
        "path": { "const": "data/source-state/fingerprints.json" },
        "present": { "type": "boolean" },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": { "type": "integer", "minimum": 0 },
        "source_count": { "type": "integer", "minimum": 0 },
        "latest_retrieved_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "release_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_path", "checksums_path"],
      "properties": {
        "manifest_path": { "type": "string", "pattern": "^data/releases/[^/]+/manifest\\.json$" },
        "checksums_path": { "type": "string", "pattern": "^data/releases/[^/]+/checksums\\.txt$" }
      }
    },
    "feed_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "media_type", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "pattern": "^data/(feeds|indexes)/" },
          "media_type": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "freshness_policy": {
      "type": "string",
      "pattern": "no raw provider content"
    }
  }
}
